# Server Configuration
PORT=3001
NODE_ENV=production

# Claude CLI Bridge Configuration
# Note: These values will be used by the bridge to ensure the CLI has the correct API context.
# Make sure your CLI is already logged in (run: claude login)
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=your-api-key-here

# Workspace Configuration
# The root directory for the UI file browser
# Set to / for full system access (caution!)
WORKSPACES_ROOT=/root

# Optional: Database path
# DATABASE_PATH=/path/to/claude-ui.db
